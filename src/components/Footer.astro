---
import Contact from "./Contact.astro";
import tipo from  '../assets/tipo-logo.svg'
import Button from "./Button.astro";
---
<section class="bg-theme-depths fixed bottom-0 left-0 w-full z-0 flex h-screen flex-col justify-end" id='footer'>
        <div class="flex flex-col lg:flex-row w-full md:justify-between h-screen px-8 md:px-20 mb-8 text-theme-lights max-w-500 mx-auto pt-16"><!-- div conteiner -->
            <div class="h-full flex flex-col justify-end md:justify-between"><!-- contenedor start -->
                <h1 class="prg font-medium text-theme-lights w-68 mb-12">
                    Be a part of our story. We’ll help you rise.
                </h1>
                <div class="flex mb-32 lg:hidden">
                    <Button 
                        href='#contact-window'
                        variant="darkSurface"
                        text="Book a meeting"
                    />                    
                </div>
                <div><!-- contenedor de imagen y ul -->
                    <img src={tipo.src} class="w-full align-bottom" alt="lotus" />
                    <ul class=" flex justify-between w-full mt-4 align-bottom">
                        <li><a href="#pre-about">about</a></li>
                        <li><a href="#card-conteiner-el">services</a></li>
                        <li><a href="#faq">faq</a></li> 
                    </ul>
                </div>
            </div>
                <div class="w-1/2 flex flex-col justify-between h-0 overflow-hidden lg:overflow-visible lg:h-full">
                    <Contact />
                <div class="flex lg:flex flex-col items-end justify-end visible">
                        <p>Copyright Lotus Software Development <span id="year-el"></span></p>
                        <p>Design & developed by Enciende Studio</p>
                </div>
            </div>
        </div>
    </div>
</section>
<script>

    document.addEventListener("DOMContentLoaded", ( )=>{
        const year = new Date( ).getFullYear( )
        const thisYear = document.getElementById("year-el")
        
        if (thisYear) {
            thisYear.textContent = String(year);
        }
    })


</script>