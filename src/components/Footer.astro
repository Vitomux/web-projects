---
import Contact from "./Contact.astro";
import tipo from  '../assets/tipo-logo.svg'
import Button from "./Button.astro";
---
<section class="bg-theme-depths fixed bottom-0 left-0 w-full z-0 flex flex-col justify-end">
        <div class="flex flex-col lg:flex-row w-full md:justify-between px-8 md:px-20 mb-8 text-theme-lights max-w-500 mx-auto">
            <div class="flex flex-col items-bottom pt-12">
                <div class="h-full">
                    <h1 class="prg font-medium text-theme-lights w-68 mb-12 sm:mt-20">
                        Be a part of our story. We’ll help you rise.
                    </h1>
                </div>
                <div class="flex mb-32 lg:hidden">
                    <Button 
                        href='services'
                        variant="darkSurface"
                        text="Book a meeting"
                    />                    
                </div>
                <img src={tipo.src} class="w-full align-bottom" alt="lotus" />
                <ul class=" flex justify-between w-full mt-4 align-bottom">
                        <li><a href="#card-conteiner-el">services</a></li>
                        <li><a href="#pre-about">about</a></li>
                        <li><a href="#faq">faq</a></li> 
                        <li><a href="#">contact</a></li>
                </ul>
            </div>
            <div class="w-1/2 pt-13 h-0 overflow-hidden lg:h-fit lg:overflow-visible">
                <Contact />
            <div class="hidden lg:flex flex-col items-end pt-28 justify-end visible">
                    <p>Copyright Lotus Software Development <span id="year-el"></span></p>
                    <p>Design & developed by Enciende Studio</p>
            </div>
        </div>
    </div>
    </div>
</section>
<script>

    document.addEventListener("DOMContentLoaded", ( )=>{
        const year = new Date( ).getFullYear( )
        const thisYear = document.getElementById("year-el")
        
        if (thisYear) {
            thisYear.textContent = String(year);
        }
    })


</script>