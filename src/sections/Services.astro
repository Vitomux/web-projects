---
import Card from "../components/Card.astro";
---

<section class="flex w-full flex-col text-theme-lights my-6" id="services">
    <div class="">
        <div class="flex items-center overflow-hidden" id="starter">
            <h1 class="monster-title text-nowrap items-center  my-6" id="monster">What we build</h1>
        </div>
                <Card />
    </div>
</section>
<script>
    import { gsap } from "gsap";
    import { ScrollTrigger } from "gsap/ScrollTrigger";

    gsap.registerPlugin(ScrollTrigger)

    document.addEventListener("DOMContentLoaded", ( )=> {
        const monster = document.getElementById("monster")

        gsap.fromTo( monster,
            {
            x: "8%", 
            duration: 0.8
            }, 
            {
            x: "-24%", duration: 0.8, 
            ease: "sine.in",
            scrollTrigger: {
                trigger: monster,
                start: "top bottom",
                end: "68% top",
                scrub: true,
           //     markers: true,
            }
        })
    })
</script>