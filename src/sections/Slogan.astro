<section>
        <div class="flex flex-col w-full h-[348svh] relative bg-theme-lights-bg" id="track-el">
            <div class="flex flex-col justify-center rounded-1xl bg-gradient-slogan w-full h-dvh  text-theme-lights items-center sticky top-0" id="slogan-box">
                <div class="flex flex-col w-full  items-center justify-items-start absolute" id="experience-arr">
                    <h1 class="title-secondary leading-0">Built with</h1>
                    <h1 class="title-principal leading-0">experience</h1>
                </div>
                <div class="flex flex-col w-full  items-center justify-center absolute" id="clarity-arr">
                    <h1 class="title-secondary leading-0">Guided with</h1>
                    <h1 class="title-principal leading-0">clarity</h1>
                </div>
            </div>
        </div>
</section>

<script>
    
    import { gsap } from 'gsap';
    import { SplitText } from 'gsap/SplitText';
    import { ScrollTrigger } from 'gsap/ScrollTrigger';

document.addEventListener("DOMContentLoaded", () => {
    gsap.registerPlugin(SplitText, ScrollTrigger);

    document.fonts.ready.then(() => {
        // Config central
        const TOTAL = 5;
        const SCENES = [
            { id: "experience-arr", inAt: 0,   outAt: 1   },
            { id: "clarity-arr",    inAt: 2.5, outAt: 3.6 },
        ];

        const snapPoints = [0, ...SCENES.flatMap(s => [s.inAt, s.outAt]), TOTAL].map(p => p / TOTAL);

        // Split y estado inicial
        const splits = SCENES.map(({ id }) => {
            const el = document.getElementById(id);
            const split = new SplitText(el, { type: "chars", mask: "chars" });
            gsap.set(split.chars, { yPercent: 105 });
            return split;
        });

        // Timeline maestra
        const master = gsap.timeline({
            scrollTrigger: {
                trigger: "#track-el",
                start: "top top",
                end: "bottom bottom",
                scrub: 0.3,
                snap: {
                    snapTo: snapPoints,
                    duration: { min: 1, max: 1 },
                    delay: 0.05,
                    ease: "power4.inOut",
                },
            },
        });

        // Tweens reutilizables
        const animIn  = (chars, at) => master.to(chars, { yPercent: 0,    stagger: 0.04, ease: "power4.out" }, at);
        const animOut = (chars, at) => master.to(chars, { yPercent: -105, stagger: 0.05, ease: "power4.in"  }, at);

        SCENES.forEach(({ inAt, outAt }, i) => {
            animIn(splits[i].chars,  inAt);
            animOut(splits[i].chars, outAt);
        });
    });
});
    
</script>